{
  "compilerOptions": {
    "target": "ES2020", // Or a later ES version depending on your target environment
    "module": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx", // Or "react" for older React versions
    "declaration": true, // Essential for SDKs to generate .d.ts files
    "declarationDir": "dist/types", // Output directory for declaration files
    "outDir": "dist", // Output directory for compiled JavaScript
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler", // Or "bundler" if using a modern bundler like Vite/Webpack 5
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true, // Recommended for build tools like Babel/SWC
    "noEmit": false, // Set to false when building an SDK
    "emitDeclarationOnly": true,
    "sourceMap": true, // Recommended for debugging
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
